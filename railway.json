{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "phases": {
                "setup": {
                    "aptPkgs": [
                        "...",
                        "fontconfig",
                        "fonts-liberation"
                    ]
                }
            }
        }
    },
    "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE"
    }
}